# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=airesearch
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/airesearch

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=0.1.0
# ENVIRONMENT controls log verbosity and /system/info output; use "production" in prod
ENVIRONMENT=local
LOG_LEVEL=INFO

# ── JWT (generate a strong secret: openssl rand -hex 32) ─────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ── Seed / Admin ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123!

# ── Ingestion ─────────────────────────────────────────────────────────────────
INGESTION_SOURCE_TYPE=file
INGESTION_SOURCE_NAME=local-ingest
INGESTION_INTERVAL_MIN=60
# Path inside the API container where JSON ingest files are read from
INGEST_DIR=/app/data/ingest

# ── CORS / Security ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
INVITE_TOKEN_TTL_DAYS=7

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── SMTP (leave SMTP_HOST empty to use console/log mode in dev) ──────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@example.com
# SMTP_TLS=true

# ── Password reset ─────────────────────────────────────────────────────────────
# RESET_TOKEN_TTL_MIN=60
