# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=airesearch
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/airesearch

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
